<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- subtle aperture rings, hint at recording -->
    <path
        android:strokeWidth="0.4"
        android:strokeColor="#551D4ED8"
        android:fillColor="#00000000"
        android:pathData="M 92,64 A 38,38 0 1,1 16,64 A 38,38 0 1,1 92,64 Z" />
    <path
        android:strokeWidth="0.4"
        android:strokeColor="#551D4ED8"
        android:fillColor="#00000000"
        android:pathData="M 84,64 A 30,30 0 1,1 24,64 A 30,30 0 1,1 84,64 Z" />

    <!-- teardrop: lens + drain -->
    <path
        android:pathData="M 54,24 C 66,44 80,56 80,64 A 26,26 0 1,1 28,64 C 28,56 42,44 54,24 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="54" android:startY="24"
                android:endX="54" android:endY="92">
                <item android:offset="0" android:color="#FF67E8F9"/>
                <item android:offset="1" android:color="#FF0EA5E9"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- iris outer dark ring -->
    <path
        android:fillColor="#FF0B1220"
        android:pathData="M 67,64 A 13,13 0 1,1 41,64 A 13,13 0 1,1 67,64 Z" />

    <!-- iris colored ring -->
    <path
        android:pathData="M 64,64 A 10,10 0 1,1 44,64 A 10,10 0 1,1 64,64 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="54" android:startY="54"
                android:endX="54" android:endY="74">
                <item android:offset="0" android:color="#FF22D3EE"/>
                <item android:offset="1" android:color="#FF0369A1"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- pupil -->
    <path
        android:fillColor="#FF0B1220"
        android:pathData="M 58.5,64 A 4.5,4.5 0 1,1 49.5,64 A 4.5,4.5 0 1,1 58.5,64 Z" />

    <!-- specular highlight on lens -->
    <path
        android:fillColor="#CCECFEFF"
        android:pathData="M 51,60 m -4,-2.5 a 4,2.5 0 1,0 8,0 a 4,2.5 0 1,0 -8,0 Z" />
</vector>
