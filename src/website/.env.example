# Action Camera Catch — example environment file.
# Copy to .env and fill in real values, or pass via docker-compose env_file.

# ---- Azure Blob Storage (choose ONE of the two modes) ----

# Mode A: full connection string (developer convenience).
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net

# Mode B: account name + SAS token.
# The SAS *must* be account-level with List Containers permission. Service SAS is not enough.
# AZURE_STORAGE_ACCOUNT_NAME=mystorage
# AZURE_STORAGE_SAS_TOKEN=sv=2024-08-04&ss=b&srt=sco&sp=rl&...

# ---- Local filesystem ----
DOWNLOAD_ROOT=/data

# ---- HTTP ----
HTTP_PORT=8080

# ---- Throughput tuning ----
MIN_CONCURRENCY=2
MAX_CONCURRENCY=8

# ---- Misc ----
LOG_LEVEL=info
